# Register a Single-page application in Microsoft Entra admin center.
# Add http://localhost:5173 as a SPA redirect URI.
VITE_MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Use a tenant GUID for single-tenant, or "common" for supported work/personal accounts.
VITE_MICROSOFT_TENANT_ID=common

# Optional digital-signature gateways. Endpoints must implement POST /v1/pdf/sign.
# Prefer a same-origin reverse proxy such as /signing-api for remote signing.
VITE_SIGNING_API_URL=
VITE_USB_SIGNING_AGENT_URL=
